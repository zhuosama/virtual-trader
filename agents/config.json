{
  "agents": {
    "market_analyst": {
      "enabled": true,
      "timeout": 300,
      "retry_count": 3
    },
    "execution_planner": {
      "enabled": true,
      "timeout": 300,
      "retry_count": 3
    },
    "risk_controller": {
      "enabled": true,
      "timeout": 180,
      "retry_count": 2
    },
    "review_agent": {
      "enabled": true,
      "timeout": 600,
      "retry_count": 2
    },
    "strategy_maintainer": {
      "enabled": true,
      "timeout": 300,
      "retry_count": 2
